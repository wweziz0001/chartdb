# Frontend
VITE_API_BASE_URL=
VITE_ENABLE_SERVER_PERSISTENCE=true
VITE_OPENAI_API_KEY=
VITE_OPENAI_API_ENDPOINT=
VITE_LLM_MODEL_NAME=
