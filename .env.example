# Copy this file to .env and adjust for your environment before deployment.

# Frontend runtime configuration
VITE_OPENAI_API_KEY=
VITE_OPENAI_API_ENDPOINT=
VITE_LLM_MODEL_NAME=
VITE_API_BASE_URL=
VITE_HIDE_CHARTDB_CLOUD=true
VITE_DISABLE_ANALYTICS=true

# Local development proxy target for `npm run dev:web`
CHARTDB_API_PROXY=http://localhost:4010

# Docker Compose exposed ports
CHARTDB_WEB_PORT=8080
CHARTDB_API_PORT=4010
CHARTDB_POSTGRES_PORT=5432

# PostgreSQL container settings for the local stack
CHARTDB_POSTGRES_DB=chartdb
CHARTDB_POSTGRES_USER=chartdb
CHARTDB_POSTGRES_PASSWORD=replace-with-a-local-dev-password

# Backend runtime settings
CHARTDB_API_HOST=0.0.0.0
CHARTDB_CORS_ORIGIN=http://localhost:8080
CHARTDB_TRUST_PROXY=false
CHARTDB_SECRET_KEY=replace-with-a-long-random-secret
CHARTDB_DATA_DIR=.chartdb-data
CHARTDB_APP_DB_PATH=
CHARTDB_METADATA_DB_PATH=
CHARTDB_LOG_LEVEL=info
CHARTDB_AUTH_MODE=disabled
CHARTDB_AUTH_EMAIL=
CHARTDB_AUTH_PASSWORD=
CHARTDB_AUTH_DISPLAY_NAME=ChartDB Owner
CHARTDB_BOOTSTRAP_SETUP_CODE=
CHARTDB_BOOTSTRAP_SETUP_CODE_TTL_MS=900000
CHARTDB_BOOTSTRAP_SETUP_CODE_MAX_ATTEMPTS=10
CHARTDB_BOOTSTRAP_ADMIN_EMAIL=
CHARTDB_SESSION_TTL_HOURS=168
CHARTDB_SESSION_COOKIE_NAME=chartdb_session
CHARTDB_SESSION_COOKIE_SECURE=
CHARTDB_OIDC_ISSUER=
CHARTDB_OIDC_CLIENT_ID=
CHARTDB_OIDC_CLIENT_SECRET=
CHARTDB_OIDC_REDIRECT_URL=
CHARTDB_OIDC_LOGOUT_URL=
CHARTDB_OIDC_SCOPES=openid profile email
CHARTDB_DEFAULT_PROJECT_NAME=My Diagrams
CHARTDB_DEFAULT_OWNER_NAME=Local Owner
